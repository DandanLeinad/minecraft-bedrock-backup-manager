# Auto detect text files and normalize line endings to LF
* text=auto eol=lf
*.py text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.toml text eol=lf

# Binary files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.jar binary
*.pyc binary
*.pyo binary
