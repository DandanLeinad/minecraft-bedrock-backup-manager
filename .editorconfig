# EditorConfig (https://editorconfig.org/)
# Padroniza configurações de editor entre diferentes IDEs

root = true

[*]
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
end_of_line = lf

[*.py]
indent_size = 4
max_line_length = 88

[*.{json,yml,yaml,toml}]
indent_size = 2

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
